ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
PORT=3000
DEMO_FALLBACK_ENABLED=false

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=leafscan
DB_USER=root
DB_PASSWORD=

# Auth / Session
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Base URL used when building password-reset links (no trailing slash).
# Defaults to http://localhost:PORT when not set.
APP_URL=http://localhost:3000
